# Copy this file to .env.local and fill in real values. Never commit .env or .env.local.

# PostgreSQL connection string. Prisma 7 reads this via prisma.config.ts (dotenv),
# not from the schema.prisma datasource block.
DATABASE_URL=

# Auth.js. Generate a secret with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=
# Required for self-hosted (non-Vercel) deployments — see README "Auth Secret" section.
AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email magic-link sign-in via Resend — https://resend.com/api-keys
# Both are required together (or leave both blank to disable email sign-in).
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=

# Plaid (Sandbox only until explicitly approved for production use)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# Base64-encoded 32-byte (256-bit) key for AES-256-GCM token encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

APP_URL=http://localhost:3000
